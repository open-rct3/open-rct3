{
  "tasks": {
    "dev:desktop": "deno run --env -A clients/desktop/main.ts",
    "dev:serve": "npx wmr serve --public clients/website/_site --out clients/website/_site",
    "dev:website": "deno run --watch --allow-env --allow-net --allow-sys --allow-run --allow-read --allow-write=./clients/website/_site clients/website/dev.ts",
    "watch": "deno run --env --watch -A clients/desktop/main.ts",
    "lint": "deno check clients/desktop/main.ts clients/isomorphic/main.ts",
    "build": "make",
    "build:desktop": "deno compile --env --no-prompt -A --output bin/OpenRCT3 clients/desktop/main.ts",
    "build:isomorphic": "deno run --allow-env --allow-net --allow-sys --allow-read --allow-write=./clients/website clients/isomorphic/build.ts",
    "build:website": "deno run --allow-env --allow-net --allow-sys --allow-run --allow-read --allow-write=./clients/website/_site clients/website/build.ts"
  },
  "imports": {
    "@deno/emit": "jsr:@deno/emit@^0.45.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/async": "jsr:@std/async@1",
    "@std/cli": "jsr:@std/cli@^1.0.5",
    "@std/cli/": "jsr:/@std/cli@^1.0.5/",
    "@std/fs": "jsr:@std/fs@^1.0.2",
    "@std/media-types": "jsr:@std/media-types@^1.0.3",
    "@std/path": "jsr:@std/path@^1.0.3",
    "@webview/webview": "jsr:@webview/webview@^0.8.0",
    "lume": "https://deno.land/x/lume@v2.2.4/mod.ts",
    "lume/": "https://deno.land/x/lume@v2.2.4/"
  },
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "h",
    "types": [
      "lume/types.ts"
    ],
    "noImplicitOverride": false
  },
  "fmt": {
    "lineWidth": 120,
    "semiColons": true,
    "unstableCss": true,
    "unstableHtml": true,
    "unstableYaml": true
  }
}
