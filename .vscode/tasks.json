{
  // See https://code.visualstudio.com/docs/editor/tasks#vscode
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "make",
      "problemMatcher": [
        "$deno-lint"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "make test",
      "problemMatcher": [
        "$deno-test"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "OpenRCT3",
      "type": "shell",
      "command": "dotnet run --project OpenRCT3/OpenRCT3.csproj",
      "group": {
        "kind": "run",
        "isDefault": true
      }
    },
    {
      "label": "Dumper",
      "type": "shell",
      "command": "dotnet run --project Dumper/Dumper.csproj"
    }
  ]
}
